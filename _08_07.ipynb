    "n=int(input(\"sayi girin: \"))\n",
    "if n<=1:\n",
    "    print(\"asal değildir\")\n",
    "    \n",
    "else:\n",
    "   \n",
    "    asal=True\n",
    "    i=2\n",
    "    while i<n:\n",
    "     \n",
    "        if n%i==0:\n",
    "            asal=False\n",
    "            break\n",
    "        else:\n",
    "            i+=1\n",
    "print(f\"{asal}\") \n",
    "    \n",
    "            \n",
    "        \n",
    "    "
   ]
  }
