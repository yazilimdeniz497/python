   "source": [
    "sayilar=[-4,-5,8,9,2]\n",
    "pozitif_toplam=0\n",
    "negatif_toplam=0\n",
    "for sayi in sayilar:\n",
    "  if sayi>0:\n",
    "   pozitif_toplam+=sayi\n",
    "   print(f\"Toplam pozitif sayilar:{pozitif_toplam}\")\n",
    "  elif sayi<0:\n",
    "   negatif_toplam+=sayi\n",
    "   print(f\"Toplam negatif sayilar:{negatif_toplam}\")\n",
    "    "
   ]
