    "sentence=input(\"bir cümle giriniz: \")\n",
    "sentence=sentence.replace(\" \",\"\")\n",
    "print(sentence)\n",
    "frequency={}\n",
    "for char in sentence:\n",
    "    \n",
    "    if char in frequency:\n",
    "        frequency[char]+=1\n",
    "    else:\n",
    "        frequency[char]=1\n",
    "   \n",
    "print(frequency)\n",
    "\n"
